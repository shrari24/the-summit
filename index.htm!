<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>القمة PRO - نسخة الأرباح</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- هنا سيتم وضع كود جوجل AdSense للويب أو AdMob لاحقاً -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap');
        body { margin: 0; overflow: hidden; font-family: 'Cairo', sans-serif; background: #020617; color: white; touch-action: none; }
        .glass { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.1); border-radius: 2rem; }
        #joy-base { position: absolute; bottom: 40px; left: 40px; width: 100px; height: 100px; background: rgba(255,255,255,0.05); border-radius: 50%; border: 1px solid rgba(255,255,255,0.1); }
        #joy-stick { position: absolute; top: 30px; left: 30px; width: 40px; height: 40px; background: white; border-radius: 50%; }
        .btn-act { width: 75px; height: 75px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.7); border: 2px solid rgba(255,255,255,0.2); font-size: 1.5rem; }
    </style>
</head>
<body>
    <div id="ui-layer" class="absolute inset-0 pointer-events-none z-50">
        <!-- القائمة الرئيسية -->
        <div id="menu" class="absolute inset-0 glass flex flex-col items-center justify-center p-8 pointer-events-auto">
            <h1 class="text-7xl font-black italic mb-2 text-white uppercase italic">القمة</h1>
            <p class="text-blue-500 font-bold tracking-[0.4em] mb-10 text-[10px] uppercase">OctaCon Monetized Edition</p>
            
            <div class="w-full max-w-sm space-y-4">
                <div class="bg-slate-900/80 p-5 rounded-2xl border border-slate-700 text-center">
                    <span class="text-slate-500 text-[10px] font-bold uppercase block">رصيد الذهب</span>
                    <span id="gold-total" class="text-3xl font-black text-yellow-500">0 🪙</span>
                </div>
                <button onclick="start()" class="w-full py-7 bg-blue-600 rounded-[2.5rem] font-black text-2xl shadow-2xl active:scale-95">بدء المعركة</button>
                <button onclick="showAd()" class="w-full py-4 bg-slate-800 rounded-2xl text-xs font-bold text-yellow-500 border border-yellow-600/30">📺 شاهد إعلان لربح 500 ذهبة</button>
            </div>
        </div>

        <!-- الواجهةHUD -->
        <div id="hud" class="hidden w-full h-full p-6 flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <div class="glass px-6 py-3 flex items-center gap-3">
                    <span class="text-blue-500 font-black">👥</span>
                    <span id="alive" class="text-xl font-black">100</span>
                </div>
                <div class="glass px-6 py-3 flex items-center gap-3">
                    <span class="text-yellow-500 font-black">🪙</span>
                    <span id="gold-session" class="text-xl font-black">0</span>
                </div>
            </div>
            
            <div id="controls" class="hidden w-full h-full relative pointer-events-auto">
                <div id="joy-base"><div id="joy-stick"></div></div>
                <div class="absolute bottom-10 right-10 flex flex-col gap-5">
                    <button onmousedown="shooting=true" onmouseup="shooting=false" ontouchstart="shooting=true" ontouchend="shooting=false" class="btn-act bg-red-600 text-3xl">🔥</button>
                    <button onclick="build()" class="btn-act bg-blue-600 text-xl">🧱</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, player, clock, state='MENU', gold=0, joy={x:0, y:0}, shooting=false;
        let enemies = [], bullets = [];

        function init() {
            scene = new THREE.Scene(); scene.background = new THREE.Color(0x020617);
            camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
            renderer = new THREE.WebGLRenderer({ antialias: true }); renderer.setSize(window.innerWidth, window.innerHeight);
            document.body.appendChild(renderer.domElement);
            scene.add(new THREE.HemisphereLight(0xffffff, 0x444444, 1.2));
            const grid = new THREE.GridHelper(1000, 40, 0x1e293b, 0x0f172a); scene.add(grid);
            clock = new THREE.Clock(); animate();
        }

        function start() {
            state = 'PLAY'; document.getElementById('menu').classList.add('hidden');
            document.getElementById('hud').classList.remove('hidden'); document.getElementById('controls').classList.remove('hidden');
            player = new THREE.Mesh(new THREE.BoxGeometry(2,4,2), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            player.position.y = 2; scene.add(player); player.add(camera); camera.position.set(0, 6, 15);
            for(let i=0; i<20; i++){
                let en = new THREE.Mesh(new THREE.BoxGeometry(2,4,2), new THREE.MeshPhongMaterial({color: 0xef4444}));
                en.position.set((Math.random()-0.5)*200, 2, (Math.random()-0.5)*200); scene.add(en); enemies.push(en);
            }
        }

        function showAd() {
            // هنا يتم استدعاء إعلان AdMob الحقيقي
            alert("جاري تحميل الإعلان... (ستظهر الأرباح في حسابك AdMob قريباً)");
            setTimeout(() => {
                gold += 500; document.getElementById('gold-total').innerText = gold + " 🪙";
            }, 2000);
        }

        function build() {
            let w = new THREE.Mesh(new THREE.BoxGeometry(8,6,1), new THREE.MeshPhongMaterial({color: 0x3b82f6, transparent:true, opacity:0.5}));
            let d = new THREE.Vector3(0,0,-1).applyQuaternion(player.quaternion);
            w.position.copy(player.position).add(d.multiplyScalar(8)); w.position.y=3;
            w.quaternion.copy(player.quaternion); scene.add(w);
        }

        function animate() {
            requestAnimationFrame(animate);
            if(state === 'PLAY') {
                player.rotation.y -= joy.x * 0.05; player.translateZ(-joy.y * 1.2);
                if(shooting) { /* منطق الرصاص */ }
            }
            renderer.render(scene, camera);
        }

        const b = document.getElementById('joy-base'), s = document.getElementById('joy-stick'); let active = false;
        b.addEventListener('touchstart', (e) => { active = true; e.preventDefault(); });
        window.addEventListener('touchmove', (e) => {
            if(!active) return; const r = b.getBoundingClientRect(), cx = r.left + r.width/2, cy = r.top + r.height/2;
            const tx = e.touches[0].clientX - cx, ty = e.touches[0].clientY - cy, d = Math.min(Math.sqrt(tx*tx+ty*ty), 35);
            const a = Math.atan2(ty, tx); s.style.transform = `translate(${Math.cos(a)*d}px, ${Math.sin(a)*d}px)`;
            joy = { x: (Math.cos(a)*d)/35, y: (Math.sin(a)*d)/35 };
        });
        window.addEventListener('touchend', () => { active = false; s.style.transform = ''; joy = {x:0, y:0}; });
        window.onload = init;
    </script>
</body>
</html>

