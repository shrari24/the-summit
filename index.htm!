<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OctaCon - عاصمة القمة v4.0</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap');
        body { margin: 0; overflow: hidden; font-family: 'Cairo', sans-serif; background: #020617; color: white; touch-action: none; user-select: none; }
        canvas { display: block; }
        .ui-layer { position: absolute; inset: 0; pointer-events: none; z-index: 100; }
        .interactive { pointer-events: auto; }
        .glass { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 2.5rem; }
        
        /* Joystick - QXالمطور Optimized */
        #joy-base { position: absolute; bottom: 50px; left: 50px; width: 110px; height: 110px; background: rgba(255,255,255,0.05); border-radius: 50%; border: 2px solid rgba(255,255,255,0.1); }
        #joy-stick { position: absolute; top: 30px; left: 30px; width: 50px; height: 50px; background: white; border-radius: 50%; box-shadow: 0 0 30px rgba(59, 130, 246, 0.6); }
        
        .act-btn { width: 85px; height: 85px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.8); border: 2px solid rgba(255,255,255,0.2); font-size: 2rem; transition: 0.2s; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .act-btn:active { transform: scale(0.9); background: white; color: black; }
        
        .speed-meter { position: absolute; bottom: 50px; right: 150px; width: 100px; height: 100px; border-radius: 50%; border: 4px solid rgba(59, 130, 246, 0.3); display: flex; flex-direction: column; items-center; justify-center; }
    </style>
</head>
<body>
    <div class="ui-layer">
        <!-- القائمة الرئيسية -->
        <div id="menu" class="absolute inset-0 glass flex flex-col items-center justify-center p-8 interactive">
            <h1 class="text-9xl font-black italic mb-2 tracking-tighter text-white uppercase italic">القمة</h1>
            <p class="text-blue-500 font-bold tracking-[0.5em] mb-12 text-[10px] uppercase italic">OctaCon City v4.0</p>
            <div class="w-full max-w-sm">
                <button onclick="launchCity()" class="w-full py-8 bg-blue-600 rounded-[3rem] font-black text-3xl shadow-2xl transition active:scale-95 uppercase italic">دخول العاصمة</button>
            </div>
        </div>

        <!-- الواجهةHUD -->
        <div id="hud" class="hidden w-full h-full p-8 flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <div class="glass px-6 py-3 border-blue-500/30">
                    <span id="mode-text" class="text-blue-400 text-[10px] font-bold block uppercase tracking-widest">وضعية المشي</span>
                    <span id="alive" class="text-2xl font-black">100 👥</span>
                </div>
                <div class="glass px-6 py-3 border-yellow-500/30">
                    <span class="text-yellow-400 text-xs font-bold block uppercase">ذهب OctaCon</span>
                    <span id="gold" class="text-2xl font-black text-yellow-500">0 🪙</span>
                </div>
            </div>

            <div id="controls" class="hidden w-full h-full relative interactive">
                <div id="joy-base"><div id="joy-stick"></div></div>
                <div class="absolute bottom-10 right-10 flex flex-col gap-6">
                    <button id="drive-btn" onclick="toggleVehicle()" class="act-btn bg-yellow-600 hidden">🚗</button>
                    <button id="fire-btn" onmousedown="shooting=true" onmouseup="shooting=false" ontouchstart="shooting=true" ontouchend="shooting=false" class="act-btn bg-red-600">🔥</button>
                    <button onclick="playerJump()" class="act-btn bg-slate-700 text-xl font-black">⏫</button>
                </div>
                
                <div id="speedo" class="speed-meter glass hidden">
                    <span id="speed-val" class="text-2xl font-black text-white">0</span>
                    <span class="text-[8px] uppercase font-bold text-blue-400 tracking-widest">كم/س</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, player, clock, state='MENU', gold=0, joy={x:0, y:0}, shooting=false;
        let bullets = [], enemies = [], buildings = [], roads = [], cars = [];
        let currentVehicle = null, driveMode = false;

        function init() {
            scene = new THREE.Scene(); scene.background = new THREE.Color(0x020617);
            scene.fog = new THREE.FogExp2(0x020617, 0.0015);
            camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 3000);
            renderer = new THREE.WebGLRenderer({ antialias: true }); renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            scene.add(new THREE.HemisphereLight(0x4433aa, 0x111122, 1.5));
            const sun = new THREE.DirectionalLight(0xffffff, 1.2); sun.position.set(200, 500, 200);
            scene.add(sun);

            createCity();
            clock = new THREE.Clock(); animate();
            setupJoystick();
        }

        function createCity() {
            // الأرضية
            const floor = new THREE.Mesh(new THREE.PlaneGeometry(3000, 3000), new THREE.MeshPhongMaterial({color: 0x0f172a}));
            floor.rotation.x = -Math.PI/2; floor.receiveShadow = true; scene.add(floor);

            // نظام الشوارع والمباني
            const gridSize = 100;
            for(let x = -10; x < 10; x++) {
                for(let z = -10; z < 10; z++) {
                    const posX = x * gridSize;
                    const posZ = z * gridSize;

                    // الشوارع
                    if(x === 0 || z === 0 || x % 3 === 0 || z % 3 === 0) {
                        const road = new THREE.Mesh(new THREE.PlaneGeometry(gridSize, gridSize), new THREE.MeshPhongMaterial({color: 0x1e293b}));
                        road.rotation.x = -Math.PI/2; road.position.set(posX, 0.05, posZ);
                        scene.add(road);
                        
                        // رصيف الشارع
                        const line = new THREE.Mesh(new THREE.PlaneGeometry(2, gridSize), new THREE.MeshBasicMaterial({color: 0xffff00, transparent: true, opacity: 0.3}));
                        line.rotation.x = -Math.PI/2; line.position.set(posX, 0.06, posZ);
                        scene.add(line);
                        
                        // سيارات عشوائية في الشوارع
                        if(Math.random() > 0.95) spawnCar(posX, posZ);
                    } else {
                        // كتل المباني
                        const h = 20 + Math.random() * 100;
                        const building = new THREE.Mesh(new THREE.BoxGeometry(70, h, 70), new THREE.MeshPhongMaterial({color: 0x020617}));
                        building.position.set(posX, h/2, posZ);
                        scene.add(building);
                        
                        // نوافذ مضيئة
                        const windowG = new THREE.BoxGeometry(71, 2, 71);
                        const windowM = new THREE.MeshBasicMaterial({color: 0x3b82f6, transparent: true, opacity: 0.1});
                        for(let j=5; j<h; j+=10) {
                            const win = new THREE.Mesh(windowG, windowM);
                            win.position.set(posX, j, posZ); scene.add(win);
                        }
                    }
                }
            }
        }

        function spawnCar(x, z) {
            const car = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(6, 3, 12), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            const top = new THREE.Mesh(new THREE.BoxGeometry(5, 2, 6), new THREE.MeshPhongMaterial({color: 0x1e293b}));
            top.position.y = 2.5; top.position.z = -1;
            car.add(body, top); car.position.set(x, 2, z);
            scene.add(car); cars.push(car);
        }

        function launchCity() {
            state = 'PLAY'; document.getElementById('menu').classList.add('hidden');
            document.getElementById('hud').classList.remove('hidden');
            document.getElementById('controls').classList.remove('hidden');
            
            player = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(2, 4, 2), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            player.add(body); player.position.y = 2; scene.add(player);
            player.add(camera); camera.position.set(0, 8, 18);
        }

        function toggleVehicle() {
            if(driveMode) {
                // الخروج من السيارة
                driveMode = false;
                player.visible = true;
                player.position.copy(currentVehicle.position).add(new THREE.Vector3(10, 0, 0));
                player.add(camera); camera.position.set(0, 8, 18);
                document.getElementById('speedo').classList.add('hidden');
                document.getElementById('mode-text').innerText = "وضعية المشي";
                document.getElementById('fire-btn').classList.remove('hidden');
            } else {
                // ركوب السيارة
                const nearCar = cars.find(c => c.position.distanceTo(player.position) < 15);
                if(nearCar) {
                    driveMode = true; currentVehicle = nearCar;
                    player.visible = false;
                    currentVehicle.add(camera); camera.position.set(0, 15, 30);
                    document.getElementById('speedo').classList.remove('hidden');
                    document.getElementById('mode-text').innerText = "وضعية القيادة";
                    document.getElementById('fire-btn').classList.add('hidden');
                }
            }
        }

        function playerJump() { if(!driveMode && player.position.y <= 2.2) player.position.y = 15; }

        let carSpeed = 0;
        function animate() {
            requestAnimationFrame(animate);
            const dt = clock.getDelta();

            if(state === 'PLAY') {
                if(!driveMode) {
                    // تحكم المشي
                    player.rotation.y -= joy.x * 0.05;
                    player.translateZ(-joy.y * 1.5);
                    if(player.position.y > 2) player.position.y -= 0.6;
                    
                    // كشف القرب من سيارة
                    const nearCar = cars.some(c => c.position.distanceTo(player.position) < 15);
                    document.getElementById('drive-btn').classList.toggle('hidden', !nearCar);
                } else {
                    // تحكم السيارة
                    currentVehicle.rotation.y -= joy.x * 0.03;
                    carSpeed = -joy.y * 3.0;
                    currentVehicle.translateZ(carSpeed);
                    document.getElementById('speed-val').innerText = Math.abs(Math.round(carSpeed * 50));
                }

                if(shooting) { /* نظام قتال */ }
            }
            renderer.render(scene, camera);
        }

        function setupJoystick() {
            const b = document.getElementById('joy-base'), s = document.getElementById('joy-stick');
            let active = false;
            b.addEventListener('touchstart', (e) => { active = true; e.preventDefault(); });
            window.addEventListener('touchmove', (e) => {
                if(!active) return;
                const r = b.getBoundingClientRect(), cx = r.left + r.width/2, cy = r.top + r.height/2;
                const tx = e.touches[0].clientX - cx, ty = e.touches[0].clientY - cy;
                const d = Math.min(Math.sqrt(tx*tx+ty*ty), 40), a = Math.atan2(ty, tx);
                s.style.transform = `translate(${Math.cos(a)*d}px, ${Math.sin(a)*d}px)`;
                joy = { x: (Math.cos(a)*d)/40, y: (Math.sin(a)*d)/40 };
            });
            window.addEventListener('touchend', () => { active = false; s.style.transform = ''; joy = {x:0, y:0}; });
        }

        window.onload = init;
        window.onresize = () => { camera.aspect = window.innerWidth/window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); };
    </script>
</body>
</html>

