<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OctaCon - القمة: العاصمة الواقعية</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap');
        body { margin: 0; overflow: hidden; font-family: 'Cairo', sans-serif; background: #020617; color: white; touch-action: none; user-select: none; }
        canvas { display: block; }
        .ui-screen { position: absolute; inset: 0; pointer-events: none; z-index: 100; }
        .interactive { pointer-events: auto; }
        .glass { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 2.5rem; }
        
        /* الخريطة المصغرة */
        #minimap-frame { position: absolute; top: 20px; right: 20px; width: 140px; height: 140px; border: 3px solid rgba(59, 130, 246, 0.5); border-radius: 20px; overflow: hidden; background: rgba(0,0,0,0.8); }
        #minimap-canvas { width: 100%; height: 100%; }

        /* التحكم - مطور QX */
        #joy-base { position: absolute; bottom: 50px; left: 50px; width: 110px; height: 110px; background: rgba(255,255,255,0.05); border-radius: 50%; border: 2px solid rgba(255,255,255,0.1); }
        #joy-stick { position: absolute; top: 30px; left: 30px; width: 50px; height: 50px; background: #fff; border-radius: 50%; box-shadow: 0 0 30px rgba(59, 130, 246, 0.6); }
        
        .act-btn { width: 85px; height: 85px; border-radius: 50%; display: flex; items-center; justify-center; background: rgba(0,0,0,0.8); border: 2px solid rgba(255,255,255,0.2); font-size: 2rem; transition: 0.2s; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .act-btn:active { transform: scale(0.9); background: white; color: black; }
    </style>
</head>
<body>
    <div class="ui-screen">
        <!-- القائمة -->
        <div id="menu" class="absolute inset-0 glass flex flex-col items-center justify-center p-8 interactive">
            <h1 class="text-9xl font-black italic mb-2 tracking-tighter text-white uppercase italic">القمة</h1>
            <p class="text-blue-500 font-bold tracking-[0.5em] mb-12 text-[10px] uppercase italic">OctaCon Realistic City v6.0</p>
            <button onclick="enterCity()" class="w-full max-w-sm py-8 bg-blue-600 rounded-[3rem] font-black text-3xl shadow-2xl transition active:scale-95 uppercase italic">دخول العاصمة</button>
        </div>

        <!-- HUD -->
        <div id="hud" class="hidden w-full h-full p-8 flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <div class="glass px-6 py-3 border-blue-500/30">
                    <span id="state-txt" class="text-blue-400 text-[10px] font-bold block uppercase tracking-widest">وضعية المشي</span>
                    <span id="gold-count" class="text-2xl font-black text-yellow-500">0 🪙</span>
                </div>
                
                <div id="minimap-frame"><canvas id="minimap-canvas"></canvas></div>
            </div>

            <div id="controls" class="hidden w-full h-full relative interactive">
                <div id="joy-base"><div id="joy-stick"></div></div>
                <div class="absolute bottom-10 right-10 flex flex-col gap-6">
                    <button id="car-action" onclick="toggleDrive()" class="act-btn bg-yellow-600 hidden">🚗</button>
                    <button id="shoot-btn" onmousedown="shooting=true" onmouseup="shooting=false" ontouchstart="shooting=true" ontouchend="shooting=false" class="act-btn bg-red-600">🔥</button>
                    <button onclick="playerJump()" class="act-btn bg-slate-700 text-xl font-black">⏫</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, player, clock, state='MENU', joy={x:0, y:0}, shooting=false;
        let buildings = [], vehicles = [], mapCtx, mapCanvas;
        let activeVehicle = null, driveMode = false;

        function init() {
            scene = new THREE.Scene(); scene.background = new THREE.Color(0x020617);
            scene.fog = new THREE.FogExp2(0x020617, 0.0012); // ضباب واقعي
            
            camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 3500);
            renderer = new THREE.WebGLRenderer({ antialias: true }); renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            // إضاءة احترافية
            scene.add(new THREE.HemisphereLight(0x4433aa, 0x111122, 1.5));
            const sun = new THREE.DirectionalLight(0xffffff, 1.2); sun.position.set(100, 500, 100); sun.castShadow = true;
            scene.add(sun);

            mapCanvas = document.getElementById('minimap-canvas');
            mapCtx = mapCanvas.getContext('2d');
            mapCanvas.width = 140; mapCanvas.height = 140;

            generateEnvironment();
            clock = new THREE.Clock(); animate();
            setupJoystick();
        }

        function generateEnvironment() {
            const worldSize = 3000;
            // الأرضية
            const floor = new THREE.Mesh(new THREE.PlaneGeometry(worldSize, worldSize), new THREE.MeshPhongMaterial({color: 0x0f172a}));
            floor.rotation.x = -Math.PI/2; floor.receiveShadow = true; scene.add(floor);

            const gridSpacing = 160;
            for(let x = -8; x <= 8; x++) {
                for(let z = -8; z <= 8; z++) {
                    const posX = x * gridSpacing, posZ = z * gridSpacing;

                    if(x === 0 || z === 0 || x % 3 === 0 || z % 3 === 0) {
                        // شوارع واقعية
                        const rd = new THREE.Mesh(new THREE.PlaneGeometry(gridSpacing, gridSpacing), new THREE.MeshPhongMaterial({color: 0x1e293b}));
                        rd.rotation.x = -Math.PI/2; rd.position.set(posX, 0.1, posZ);
                        scene.add(rd);
                        
                        // رصيف الشارع
                        const line = new THREE.Mesh(new THREE.PlaneGeometry(2, gridSpacing), new THREE.MeshBasicMaterial({color: 0xffff00, transparent: true, opacity: 0.2}));
                        line.rotation.x = -Math.PI/2; line.position.set(posX, 0.12, posZ);
                        scene.add(line);
                        
                        if(Math.random() > 0.93) spawnCityCar(posX, posZ);
                    } else {
                        // أبراج شاهقة
                        const h = 40 + Math.random() * 150;
                        const bGeo = new THREE.BoxGeometry(110, h, 110);
                        const bMat = new THREE.MeshPhongMaterial({color: 0x020617});
                        const tower = new THREE.Mesh(bGeo, bMat);
                        tower.position.set(posX, h/2, posZ);
                        tower.castShadow = true; tower.receiveShadow = true;
                        scene.add(tower);
                        buildings.push({x: posX, z: posZ, h: h});

                        // نوافذ مضيئة
                        const winG = new THREE.BoxGeometry(112, 1, 112);
                        const winM = new THREE.MeshBasicMaterial({color: 0x3b82f6, transparent: true, opacity: 0.1});
                        for(let i=10; i<h; i+=15) {
                            const w = new THREE.Mesh(winG, winM); w.position.set(posX, i, posZ); scene.add(w);
                        }
                    }
                }
            }
        }

        function spawnCityCar(x, z) {
            const car = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(7, 3.5, 14), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            const roof = new THREE.Mesh(new THREE.BoxGeometry(6, 2.5, 7), new THREE.MeshPhongMaterial({color: 0x1e293b}));
            roof.position.y = 3; roof.position.z = -1;
            const lightL = new THREE.Mesh(new THREE.SphereGeometry(0.5), new THREE.MeshBasicMaterial({color: 0xffffff}));
            lightL.position.set(-2, 1, -7);
            const lightR = lightL.clone(); lightR.position.x = 2;
            car.add(body, roof, lightL, lightR); car.position.set(x, 2, z);
            scene.add(car); vehicles.push(car);
        }

        function enterCity() {
            state = 'PLAY'; document.getElementById('menu').classList.add('hidden');
            document.getElementById('hud').classList.remove('hidden'); document.getElementById('controls').classList.remove('hidden');
            player = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(2.5, 5, 2.5), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            player.add(body); player.position.set(0, 3, 0); scene.add(player);
            player.add(camera); camera.position.set(0, 10, 25);
        }

        function toggleDrive() {
            if(driveMode) {
                driveMode = false; player.visible = true;
                player.position.copy(activeVehicle.position).add(new THREE.Vector3(12, 0, 0));
                player.add(camera); camera.position.set(0, 10, 25);
                document.getElementById('state-txt').innerText = "وضعية المشي";
                document.getElementById('shoot-btn').classList.remove('hidden');
            } else {
                const near = vehicles.find(v => v.position.distanceTo(player.position) < 20);
                if(near) {
                    driveMode = true; activeVehicle = near;
                    player.visible = false;
                    activeVehicle.add(camera); camera.position.set(0, 20, 45);
                    document.getElementById('state-txt').innerText = "وضعية القيادة";
                    document.getElementById('shoot-btn').classList.add('hidden');
                }
            }
        }

        function playerJump() { if(!driveMode && player.position.y <= 3.2) player.position.y = 20; }

        function updateMinimap() {
            mapCtx.fillStyle = '#000'; mapCtx.fillRect(0, 0, 140, 140);
            const mid = 70, scale = 0.2;
            buildings.forEach(b => {
                mapCtx.fillStyle = '#1e293b';
                mapCtx.fillRect(mid + (b.x-player.position.x)*scale - 4, mid + (b.z-player.position.z)*scale - 4, 8, 8);
            });
            vehicles.forEach(v => {
                mapCtx.fillStyle = '#eab308';
                mapCtx.beginPath(); mapCtx.arc(mid + (v.position.x-player.position.x)*scale, mid + (v.position.z-player.position.z)*scale, 2, 0, 7); mapCtx.fill();
            });
            mapCtx.fillStyle = '#3b82f6'; mapCtx.beginPath(); mapCtx.arc(mid, mid, 4, 0, 7); mapCtx.fill();
            mapCtx.strokeStyle = '#fff'; mapCtx.stroke();
        }

        function animate() {
            requestAnimationFrame(animate);
            if(state === 'PLAY') {
                if(!driveMode) {
                    player.rotation.y -= joy.x * 0.05;
                    player.translateZ(-joy.y * 2.2);
                    if(player.position.y > 3) player.position.y -= 0.8;
                    const nearCar = vehicles.some(v => v.position.distanceTo(player.position) < 20);
                    document.getElementById('car-action').classList.toggle('hidden', !nearCar);
                } else {
                    activeVehicle.rotation.y -= joy.x * 0.04;
                    activeVehicle.translateZ(-joy.y * 4.5);
                }
                updateMinimap();
            }
            renderer.render(scene, camera);
        }

        function setupJoystick() {
            const b = document.getElementById('joy-base'), s = document.getElementById('joy-stick'); let active = false;
            const mv = (e) => {
                if(!active) return; const r = b.getBoundingClientRect(), cx = r.left + r.width/2, cy = r.top + r.height/2;
                const tx = (e.touches ? e.touches[0].clientX : e.clientX) - cx, ty = (e.touches ? e.touches[0].clientY : e.clientY) - cy;
                const d = Math.min(Math.sqrt(tx*tx+ty*ty), 40), a = Math.atan2(ty, tx);
                s.style.transform = `translate(${Math.cos(a)*d}px, ${Math.sin(a)*d}px)`;
                joy = { x: (Math.cos(a)*d)/40, y: (Math.sin(a)*d)/40 };
            };
            b.addEventListener('touchstart', (e) => { active = true; e.preventDefault(); });
            window.addEventListener('touchmove', mv);
            window.addEventListener('touchend', () => { active = false; s.style.transform = ''; joy = {x:0, y:0}; });
        }

        window.onload = init;
        window.onresize = () => { camera.aspect = window.innerWidth/window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); };
    </script>
</body>
</html>

