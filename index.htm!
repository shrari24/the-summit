<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OctaCon - القمة v5.0</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap');
        body { margin: 0; overflow: hidden; font-family: 'Cairo', sans-serif; background: #020617; color: white; touch-action: none; user-select: none; }
        canvas { display: block; }
        .ui-layer { position: absolute; inset: 0; pointer-events: none; z-index: 100; }
        .interactive { pointer-events: auto; }
        .glass { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 2.5rem; }
        
        /* خريطة مصغرة احترافية */
        #minimap-container { position: absolute; top: 20px; right: 20px; width: 150px; height: 150px; border: 3px solid rgba(59, 130, 246, 0.5); border-radius: 20px; overflow: hidden; background: rgba(0,0,0,0.8); }
        #minimap-canvas { width: 100%; height: 100%; }

        /* Joystick - QX Developer Optimized */
        #joy-base { position: absolute; bottom: 50px; left: 50px; width: 110px; height: 110px; background: rgba(255,255,255,0.05); border-radius: 50%; border: 2px solid rgba(255,255,255,0.1); }
        #joy-stick { position: absolute; top: 30px; left: 30px; width: 50px; height: 50px; background: white; border-radius: 50%; box-shadow: 0 0 30px rgba(59, 130, 246, 0.6); }
        
        .act-btn { width: 85px; height: 85px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.8); border: 2px solid rgba(255,255,255,0.2); font-size: 2rem; transition: 0.2s; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .act-btn:active { transform: scale(0.9); background: white; color: black; }
    </style>
</head>
<body>
    <div class="ui-layer">
        <!-- القائمة الرئيسية -->
        <div id="menu" class="absolute inset-0 glass flex flex-col items-center justify-center p-8 interactive">
            <h1 class="text-8xl font-black italic mb-2 tracking-tighter text-white uppercase italic">القمة</h1>
            <p class="text-blue-500 font-bold tracking-[0.5em] mb-12 text-[10px] uppercase italic">OctaCon Map System v5.0</p>
            <div class="w-full max-w-sm">
                <button onclick="enterTheWorld()" class="w-full py-8 bg-blue-600 rounded-[3rem] font-black text-3xl shadow-2xl transition active:scale-95 uppercase italic">دخول العاصمة</button>
            </div>
        </div>

        <!-- الواجهة HUD -->
        <div id="hud" class="hidden w-full h-full p-8 flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <div class="glass px-6 py-3 border-blue-500/30">
                    <span id="mode-label" class="text-blue-400 text-[10px] font-bold block uppercase tracking-widest">المشي</span>
                    <span id="alive-count" class="text-2xl font-black">100 👥</span>
                </div>
                
                <!-- الخريطة المصغرة -->
                <div id="minimap-container">
                    <canvas id="minimap-canvas"></canvas>
                </div>
            </div>

            <div id="controls" class="hidden w-full h-full relative interactive">
                <div id="joy-base"><div id="joy-stick"></div></div>
                <div class="absolute bottom-10 right-10 flex flex-col gap-6">
                    <button id="car-btn" onclick="toggleDrive()" class="act-btn bg-yellow-600 hidden">🚗</button>
                    <button id="fire-btn" class="act-btn bg-red-600">🔥</button>
                    <button onclick="heroJump()" class="act-btn bg-slate-700 text-xl font-black">⏫</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let scene, camera, renderer, player, clock, state='MENU', joy={x:0, y:0}, shooting=false;
        let buildings = [], roads = [], vehicles = [], hostiles = [];
        let mapCanvas, mapCtx;
        let currentCar = null, isDriving = false;

        function init() {
            scene = new THREE.Scene(); scene.background = new THREE.Color(0x020617);
            scene.fog = new THREE.FogExp2(0x020617, 0.001);
            camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 3000);
            renderer = new THREE.WebGLRenderer({ antialias: true }); renderer.setSize(window.innerWidth, window.innerHeight);
            document.body.appendChild(renderer.domElement);

            scene.add(new THREE.HemisphereLight(0xffffff, 0x444444, 1.2));
            const sun = new THREE.DirectionalLight(0xffffff, 1); sun.position.set(100, 500, 100);
            scene.add(sun);

            mapCanvas = document.getElementById('minimap-canvas');
            mapCtx = mapCanvas.getContext('2d');
            mapCanvas.width = 150; mapCanvas.height = 150;

            buildTheCity();
            clock = new THREE.Clock(); animate();
            setupJoystick();
        }

        function buildTheCity() {
            const worldSize = 3000;
            const floor = new THREE.Mesh(new THREE.PlaneGeometry(worldSize, worldSize), new THREE.MeshPhongMaterial({color: 0x0f172a}));
            floor.rotation.x = -Math.PI/2; scene.add(floor);

            const grid = 150;
            for(let x = -10; x <= 10; x++) {
                for(let z = -10; z <= 10; z++) {
                    const posX = x * grid, posZ = z * grid;
                    
                    if(x === 0 || z === 0 || x % 4 === 0 || z % 4 === 0) {
                        // شوارع
                        const rd = new THREE.Mesh(new THREE.PlaneGeometry(grid, grid), new THREE.MeshPhongMaterial({color: 0x1e293b}));
                        rd.rotation.x = -Math.PI/2; rd.position.set(posX, 0.1, posZ);
                        scene.add(rd);
                        roads.push({x: posX, z: posZ});
                        if(Math.random() > 0.9) createCar(posX, posZ);
                    } else {
                        // مباني
                        const h = 40 + Math.random() * 120;
                        const b = new THREE.Mesh(new THREE.BoxGeometry(100, h, 100), new THREE.MeshPhongMaterial({color: 0x020617}));
                        b.position.set(posX, h/2, posZ);
                        scene.add(b);
                        buildings.push({x: posX, z: posZ, h: h});
                    }
                }
            }
        }

        function createCar(x, z) {
            const car = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(8, 4, 14), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            const top = new THREE.Mesh(new THREE.BoxGeometry(6, 3, 7), new THREE.MeshPhongMaterial({color: 0x1e293b}));
            top.position.y = 3; car.add(body, top);
            car.position.set(x, 2, z); scene.add(car); vehicles.push(car);
        }

        function enterTheWorld() {
            state = 'PLAY'; document.getElementById('menu').classList.add('hidden');
            document.getElementById('hud').classList.remove('hidden');
            document.getElementById('controls').classList.remove('hidden');
            
            player = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(3, 6, 3), new THREE.MeshPhongMaterial({color: 0x3b82f6}));
            player.add(body); player.position.y = 3; scene.add(player);
            player.add(camera); camera.position.set(0, 10, 25);
        }

        function toggleDrive() {
            if(isDriving) {
                isDriving = false; player.visible = true;
                player.position.copy(currentCar.position).add(new THREE.Vector3(12, 0, 0));
                player.add(camera); camera.position.set(0, 10, 25);
                document.getElementById('mode-label').innerText = "المشي";
            } else {
                const near = vehicles.find(v => v.position.distanceTo(player.position) < 20);
                if(near) {
                    isDriving = true; currentCar = near;
                    player.visible = false;
                    currentCar.add(camera); camera.position.set(0, 20, 40);
                    document.getElementById('mode-label').innerText = "القيادة";
                }
            }
        }

        function heroJump() { if(!isDriving && player.position.y <= 3.2) player.position.y = 20; }

        function drawMinimap() {
            mapCtx.fillStyle = '#000'; mapCtx.fillRect(0, 0, 150, 150);
            const center = 75;
            const scale = 0.2;

            // رسم المباني
            mapCtx.fillStyle = '#1e293b';
            buildings.forEach(b => {
                const dx = (b.x - player.position.x) * scale;
                const dz = (b.z - player.position.z) * scale;
                mapCtx.fillRect(center + dx - 5, center + dz - 5, 10, 10);
            });

            // رسم السيارات
            mapCtx.fillStyle = '#eab308';
            vehicles.forEach(v => {
                const dx = (v.position.x - player.position.x) * scale;
                const dz = (v.position.z - player.position.z) * scale;
                mapCtx.beginPath(); mapCtx.arc(center + dx, center + dz, 2, 0, Math.PI*2); mapCtx.fill();
            });

            // رسم اللاعب
            mapCtx.fillStyle = '#3b82f6';
            mapCtx.beginPath(); mapCtx.arc(center, center, 4, 0, Math.PI*2); mapCtx.fill();
            mapCtx.strokeStyle = '#fff'; mapCtx.stroke();
        }

        function animate() {
            requestAnimationFrame(animate);
            if(state === 'PLAY') {
                if(!isDriving) {
                    player.rotation.y -= joy.x * 0.05;
                    player.translateZ(-joy.y * 2.0);
                    if(player.position.y > 3) player.position.y -= 0.8;
                    const nearCar = vehicles.some(v => v.position.distanceTo(player.position) < 20);
                    document.getElementById('car-btn').classList.toggle('hidden', !nearCar);
                } else {
                    currentCar.rotation.y -= joy.x * 0.04;
                    currentCar.translateZ(-joy.y * 4.0);
                }
                drawMinimap();
            }
            renderer.render(scene, camera);
        }

        function setupJoystick() {
            const b = document.getElementById('joy-base'), s = document.getElementById('joy-stick');
            let active = false;
            b.addEventListener('touchstart', (e) => { active = true; e.preventDefault(); });
            window.addEventListener('touchmove', (e) => {
                if(!active) return;
                const r = b.getBoundingClientRect(), cx = r.left + r.width/2, cy = r.top + r.height/2;
                const tx = e.touches[0].clientX - cx, ty = e.touches[0].clientY - cy;
                const d = Math.min(Math.sqrt(tx*tx+ty*ty), 40), a = Math.atan2(ty, tx);
                s.style.transform = `translate(${Math.cos(a)*d}px, ${Math.sin(a)*d}px)`;
                joy = { x: (Math.cos(a)*d)/40, y: (Math.sin(a)*d)/40 };
            });
            window.addEventListener('touchend', () => { active = false; s.style.transform = ''; joy = {x:0, y:0}; });
        }

        window.onload = init;
        window.onresize = () => { camera.aspect = window.innerWidth/window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); };
    </script>
</body>
</html>

